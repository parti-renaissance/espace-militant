{
  "name": "vox",
  "version": "1.0.0",
  "main": "index",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "vite build --config vite.worker.config.js && expo start --web",
    "web:export": "vite build --config vite.worker.config.js && expo export -p web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prettier-watch": "onchange '**/*.ts' '**/*.tsx' '**/*.cjs' '**/*.js' '**/*.json' --exclude-path .gitignore -- prettier --write {{changed}}",
    "ts:check": "tsc --noEmit",
    "prepare:env": "tsx ./scripts/prepare-client-env.ts",
    "prepare-markers": "tsx ./scripts/prepare-action-markers.ts",
    "postinstall": "tsx ./scripts/postinstall.ts",
    "build:worker": "npx vite build --config vite.worker.config.js",
    "storybook-generate": "sb-rn-get-stories -js",
    "storybook": "cross-env STORYBOOK_ENABLED='true' expo start",
    "storybook:web": "start-storybook -p 7007",
    "storybook:ios": "cross-env STORYBOOK_ENABLED='true' expo start --ios",
    "storybook:android": "cross-env STORYBOOK_ENABLED='true' expo start --android",
    "android:shake": "adb shell input keyevent 82",
    "knip": "knip",
    "eas-build-pre-install": "corepack enable && cd ../.. && yarn install"
  },
