{
  "extends": "./tsconfig.base",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "tamagui.config": ["./tamagui.config.ts"],
      "assets/*": ["./assets/*"]
    },
    "moduleSuffixes": [".ios", ".android", ".native", ""]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts", ".expo/types/**/*.ts", "expo-env.d.ts", "scripts/prepare-client-env.ts", "queryError.d.ts"]
}
